{
  "name": "Node.js Developer Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bookworm",

  // 1. Add essential features (CLI tools, Docker, etc.)
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true
    }
  },

  // 2. Automate setup: Install dependencies as soon as the container builds
  "postCreateCommand": "npm install",

  // 3. Port Forwarding: Map container ports to your local machine
  // 3000 (React/Next.js), 5000 (Express), 9229 (Node Debugger)
  "forwardPorts": [3000, 5000, 9229],

  // 4. VS Code Customizations: Force specific extensions and settings
  "customizations": {
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "christian-kohler.npm-intellisense",
        "ms-vscode.vscode-typescript-next",
        "firsttris.vscode-jest-runner"
      ]
    }
  },

  // 5. Use the non-root 'node' user for better security/permission mapping
  "remoteUser": "node"
}